rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Project attachments — pro users only (validated in Cloud Function)
    match /projects/{projectId}/attachments/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024; // 50MB max
    }
  }
}
