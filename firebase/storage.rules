rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Teacher application documents — only owner + admin
    match /teacher-applications/{uid}/{filename} {
      allow read:  if request.auth != null && (request.auth.uid == uid || request.auth.token.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024; // 10 MB max
    }

    // Project attachments (pro feature)
    match /projects/{projectId}/attachments/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024; // 50 MB max
    }
  }
}
